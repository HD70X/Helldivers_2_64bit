[autoload]

GameEvent="*res://Script/Core/game_event.gd"
PlayerData="*res://Script/GameData/PlayerData/player_data.gd"
ItemDatabase="*res://Script/GameData/Item/item_database.gd"
SaveManager="*res://Script/GameData/PlayerData/save_manager.gd"

